# ce-builder-studio

## Environment variables

# Port (default 3001)
PORT=3001

# ConvEngine backend base URL — used for proxying agent LLM calls and MCP tools
# when the graph runner encounters agent/mcp blocks.
CONVENGINE_BASE=http://localhost:8080/api/v1

# LLM provider keys (used for direct LLM calls without proxying to ConvEngine)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Postgres — for workspace persistence
# DATABASE_URL=postgresql://user:pass@localhost:5432/convengine
